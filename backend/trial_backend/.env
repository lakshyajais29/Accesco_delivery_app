# ── .env  (copy to project root, never commit) ────────────────────────────────
# Database
DATABASE_URL = "sqlite+aiosqlite:///./trial.db"
# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase Cloud Messaging (FCM v1 — service-account JSON path)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/accesco-firebase-adminsdk.json
FCM_PROJECT_ID=accesco-living

# Rider Service (internal microservice or mock URL during dev)
RIDER_SERVICE_URL=http://localhost:8001

# Trial config
TRIAL_DURATION_SECONDS=900        # 15 minutes
TRIAL_SESSION_TTL_SECONDS=3600    # Redis key TTL (1 hr safety margin)

# Stripe (or Razorpay — swap payment_service.py accordingly)
RAZORPAY_KEY_ID=rzp_test_XXXX
RAZORPAY_KEY_SECRET=XXXX
